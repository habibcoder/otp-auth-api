PORT=3000

# Set to true for local development — OTPs are printed to console, no SMS is sent
DEV_MODE=true

SMS_SERVICE_PROVIDER=ALPHASMS

# Your sms.net.bd API key (required when DEV_MODE=false)
ALPHASMS_API_KEY=your_sms_net_bd_api_key_here
ALPHASMS_API_URL=https://api.sms.net.bd/sendsms

# Your sendmysms.net API key (required when DEV_MODE=false)
SENTMYSMS_API_KEY=your_sendmysms_net_api_key_here
SENTMYSMS_USER=your_sendmysms_net_username_here
SENTMYSMS_API_URL=https://sendmysms.net/api.php

# Brand name used in the OTP message body
BRAND_NAME=My App
